# Sam AI Bot Environment Variables
# Copy this file to .env and fill in your values
#
# WARNING: Never commit real credentials to version control.
# The .env file is git-ignored — keep your secrets there, not here.

# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Google Gemini API Key (get from Google AI Studio: https://ai.google.dev/)
GOOGLE_API_KEY=your_google_api_key_here

# Server Configuration (optional)
PORT=8000
USE_WEBHOOK=false

# Polygon / Web3 Configuration
# Public RPC — replace with a dedicated node URL (e.g. Alchemy, Infura) for production use
POLYGON_RPC_URL=https://polygon-rpc.com

# Polygonscan API key — used for enhanced on-chain data (optional)
# Get yours at https://polygonscan.com/apis
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here
